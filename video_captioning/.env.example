# Copy to .env for local development. The submitted container reads these
# purely from the real environment at `docker run` time -- Track 2 does not
# inject a Fireworks key or model allowlist, these are your own account's.

# PRIMARY captioning backend -- Gemma 4 via the Gemini API. Leave
# GEMINI_API_KEY unset/blank to skip this backend entirely (Fireworks then
# becomes primary automatically, see pipeline/captioner.py). Get a key at
# aistudio.google.com/apikey. Fireworks is deliberately the first fallback
# below -- it absorbs Gemini rate limiting (Gemini's free/low tiers are the
# tightest of the three backends) as well as any other Gemini failure.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_VISION_MODEL=gemma-4-26b-a4b-it
GEMINI_TEXT_MODEL=gemma-4-26b-a4b-it

FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional: primary transcription backend (Groq-hosted whisper-large-v3).
# Falls back to a local faster-whisper model automatically if unset or if
# the Groq call fails -- see pipeline/audio.py. Get a key at console.groq.com.
# NEVER commit a real key here or bake one into the Dockerfile -- Track 2
# images must be publicly pullable, so anything baked in is extractable.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=whisper-large-v3

# Verify these against your Fireworks account's current model catalog
# before submitting -- availability changes over time, and not every
# deployed model accepts image input (confirmed by testing every model on
# one real account: only kimi-k2p6 out of 7 deployed models accepted a real
# image_url message -- gpt-oss-120b/glm-5p1/glm-5p2/deepseek-v4-pro all
# rejected multimodal content). If FIREWORKS_VISION_MODEL doesn't actually
# support vision, every describe_scene() call falls straight through to the
# Groq fallback -- check the logs for repeated 400s to catch this.
# Keep FIREWORKS_TEXT_MODEL as gpt-oss-120b, NOT kimi-k2p6, even though
# kimi-k2p6 is already loaded for vision -- tested head-to-head on the
# combine/captions text steps: kimi-k2p6 averaged 79s/call vs gpt-oss-120b's
# 6.2s (13x slower), AND kimi-k2p6 leaked its raw reasoning process as
# visible prose in the output ("The user wants me to synthesize... Let me
# draft...") even with an explicit "output ONLY the final answer" prompt
# instruction -- gpt-oss-120b never did either of these across dozens of
# real test calls. If you change this, re-verify against your account.
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/gpt-oss-120b
# Captioning FALLBACK: if Fireworks is unavailable or errors out,
# pipeline/captioner.py retries the same describe+style flow against Groq
# instead of giving up. GROQ_VISION_MODEL must be vision-capable (verify
# against your Groq account's catalog); GROQ_TEXT_MODEL should NOT be a
# reasoning model -- reasoning models emit a <think> block that breaks
# strict JSON-mode validation on the styled-captions step.
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Local dev I/O paths ONLY -- do not set these in the real .env used to
# build the submission image. The container hardcodes /input/tasks.json and
# /output/results.json per the Track 2 contract (config.py's defaults);
# overriding them here would break that contract inside the container.
# INPUT_TASKS_PATH=./examples/tasks.json
# OUTPUT_RESULTS_PATH=./outputs/results.json

# Runtime tuning
MAX_TOTAL_RUNTIME_SECONDS=540
MAX_PARALLEL_TASKS=3
MAX_KEYFRAMES=6
MAX_SCENE_DESCRIBE_PARALLEL=3
SPRITE_TILE_SIZE=220
SPRITE_MAX_COLS=4
SPRITE_MAX_TILES=12
SPRITE_JPEG_MAX_SIDE=1024

# Audio pipeline (kept on by default -- disable for a pure-vision, faster run)
ENABLE_AUDIO_PIPELINE=true
ENABLE_SOURCE_SEPARATION=true
ENABLE_BACKGROUND_CLASSIFICATION=true
WHISPER_MODEL_SIZE=small
AUDIO_STAGE_BUDGET_SECONDS=45
